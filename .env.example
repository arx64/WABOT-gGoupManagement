# ============================================
# Google Drive OAuth2 Configuration
# ============================================

# 1. Buat project di Google Cloud Console (https://console.cloud.google.com)
# 2. Enable Google Drive API
# 3. Buat OAuth2 credentials (Desktop App type)
# 4. Copy Client ID dan Client Secret ke bawah ini:

GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost

# 5. Jalankan: node auth/generateToken.js
# 6. Copy refresh token yang dihasilkan ke bawah ini:

GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# 7. (Optional) ID Folder Google Drive tempat file akan disimpan
#    Biarkan kosong jika ingin disimpan di root My Drive
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here

# 8. Buat file bisa diakses publik (1 = ya, 0 = tidak)
DRIVE_PUBLIC=0

# ============================================
# Other Configurations
# ============================================
EDLINK_BEARER=your_edlink_token_here
EDLINK_NOTIFY_JID=your_whatsapp_jid_here

# ============================================
# Auto View-Once Configuration
# ============================================
# Nomor yang akan auto-convert view-once messages menjadi file biasa
# Format: Nomor WhatsApp separated by comma (62xxxxx)
# Example: AUTO_VIEW_ONCE_JIDS=6281234567890,6281234567891,6282988223456
# Leave empty or comment to disable
# AUTO_VIEW_ONCE_JIDS=

# ============================================
# Auto View Story Configuration
# ============================================
# Nomor yang akan auto-view/read story-nya secara otomatis
# Format: 
#   - Gunakan * untuk auto view SEMUA story (dari semua nomor)
#   - Atau list nomor specific: 6281234567890,6281234567891
# Example 1: AUTO_VIEW_STORY_JIDS=*                           (view semua story)
# Example 2: AUTO_VIEW_STORY_JIDS=6281234567890,6281234567891 (view story dari nomor tertentu)
# Leave empty or comment to disable
# AUTO_VIEW_STORY_JIDS=
